rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - users can only upload to their own folder
    match /profile-photos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Voice messages - users can only upload to their conversation folder
    match /voice_messages/{conversationId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == conversationId.split('_')[0] ||
        request.auth.uid == conversationId.split('_')[1]
      );
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType in ['admin', 'instructor'];
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isStaff();
    }

    // Main attendance records
    match /attendance/{attendanceId} {
      // Staff can read all attendance records
      allow read: if isStaff();
      
      // Students can read their own attendance records
      allow read: if isAuth() && resource.data.studentId == request.auth.uid;
      
      // Staff can do anything
      allow write: if isStaff();
      
      // Students can CREATE their own check-in record
      allow create: if isAuth() && request.resource.data.studentId == request.auth.uid;
      
      // Students can UPDATE (add check-out time) to their own record.
      // Use diff() so Timestamp equality on checkInTime cannot spuriously fail after merge.
      allow update: if isAuth() && resource.data.studentId == request.auth.uid
                    && resource.data.checkOutTime == null
                    && request.resource.data.checkOutTime != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['checkOutTime', 'status', 'updatedAt', 'location']);
    }

    // Daily attendance summary (used by DailyAttendanceService)
    match /dailyAttendance/{recordId} {
      allow read: if isAuth();
      allow write: if isStaff();
      allow create: if isAuth() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuth() && resource.data.studentId == request.auth.uid;
    }

    // QR codes and system config — students need READ to validate codes
    match /system_config/{docId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    // Admin audit log
    match /admin_actions/{docId} {
      allow read, write: if isStaff();
    }

    // Events
    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isStaff();
    }

    match /ticketTypes/{id} { allow read, write: if isAuth(); }
    match /registrations/{id} { allow read, write: if isAuth(); }
    match /eventResources/{id} { allow read, write: if isAuth(); }
    match /feedback/{id} { allow read, write: if isAuth(); }
    match /students/{id} { allow read, write: if isAuth(); }

    // Conversations
    match /conversations/{conversationId} {
      function isParticipant() {
        return isAuth() && (
          request.auth.uid == conversationId.split('_')[0] ||
          request.auth.uid == conversationId.split('_')[1]
        );
      }
      allow read, write: if isParticipant();
      match /messages/{messageId} {
        allow read, write: if isParticipant();
      }
    }
  }
}
